{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IPNOVA VPN",
  "version": "0.1.0",
  "identifier": "com.ipnova.windows-vpn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IPNOVA VPN",
        "width": 960,
        "height": 640,
        "minWidth": 880,
        "minHeight": 580,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": {
      "resources/sing-box/windows-amd64/sing-box.exe": "sing-box/windows-amd64/",
      "resources/sing-box/windows-amd64/wintun.dll": "sing-box/windows-amd64/"
    }
  }
}
